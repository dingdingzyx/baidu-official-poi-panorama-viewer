include LICENSE
include README.md
include CONTRIBUTING.md
include SECURITY.md
include CHANGELOG.md
include .env.example
include pyproject.toml
include requirements.txt
include requirements-dev.txt
include wmx.py

recursive-include official_viewer/static *.css *.html *.js
recursive-include official_tests *.py *.cjs
recursive-include docs *.md

exclude .env
prune build
prune dist
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.egg-info
global-exclude *.pem
global-exclude *.key
global-exclude *.p12
global-exclude *.pfx
