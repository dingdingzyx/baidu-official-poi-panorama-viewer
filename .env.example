# Copy this file to .env, fill the two keys locally, and never commit .env.
# Server AK: documented Place API, restricted to your actual public egress IP.
BAIDU_MAP_SERVER_AK=

# Browser AK: JavaScript API, restricted to 127.0.0.1,localhost for local use.
BAIDU_MAP_BROWSER_AK=

# Conservative local guards. Set no higher than the quota authorized in your
# Baidu Map Open Platform console.
BAIDU_MAP_DAILY_PLACE_LIMIT=4500
BAIDU_MAP_DAILY_PANORAMA_LIMIT=100

# Optional local directory for the counter-only usage ledger.
# PANO_VIEWER_HOME=.official-viewer
